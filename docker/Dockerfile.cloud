# ── 云端服务镜像 ──────────────────────────────────────────
# python:3.10-slim + 项目依赖 + FastAPI 入口

FROM python:3.10-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    libgl1-mesa-glx libglib2.0-0 libgomp1 \
    && rm -rf /var/lib/apt/lists/*

COPY pyproject.toml ./

RUN pip install --no-cache-dir \
    fastapi[standard] uvicorn[standard] python-multipart \
    langchain langchain-openai langchain-community langgraph \
    sqlalchemy[asyncio] asyncpg pgvector alembic \
    sentence-transformers pydantic pydantic-settings \
    python-jose passlib[bcrypt] psutil httpx loguru python-dotenv \
    gdown kagglehub ultralytics

COPY cloud/ ./cloud/
COPY alembic.ini ./

EXPOSE 8000

CMD ["uvicorn", "cloud.main:app", "--host", "0.0.0.0", "--port", "8000"]
