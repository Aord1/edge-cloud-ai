# ============================================================
# 边云协同智能系统 — 环境变量模板
# 复制为 .env 后填入实际值
# ============================================================

# 数据库密码
DB_PASSWORD=

# LLM API Key（OpenAI / 兼容接口）
LLM_API_KEY=

# LLM 模型名称（默认 gpt-4o）
LLM_MODEL=gpt-4o

# LLM API 地址（默认 OpenAI 官方；第三方/代理时填入）
# LLM_BASE_URL=

# LLM 温度（0-1，默认 0.3）
# LLM_TEMPERATURE=0.3

# MQTT Broker 密码
MQTT_PASSWORD=

# JWT 签名密钥（生产环境请更换）
JWT_SECRET_KEY=
